    "preview:prod": "npm run build && vite preview",
    "lint": "eslint . --ext .ts,.tsx,.js",
    "format": "prettier --write \"**/*.(js|ts|tsx|md)\" && eslint . --ext .ts,.tsx,.js --fix"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.0.1",
    "@mui/material": "^9.0.1",
    "@mui/x-data-grid": "^9.4.0",
    "@mui/x-tree-view": "^9.4.0",
    "@tauri-apps/plugin-dialog": "^2.2.1",
    "@tauri-apps/plugin-fs": "^2.2.1",
    "@tauri-apps/plugin-shell": "^2.2.1",
    "@wirestate/core": "^1.0.0-experimental.2",
    "@wirestate/react": "^1.0.0-experimental.2",
    "@wirestate/react-mobx": "^1.0.0-experimental.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.17.0",
